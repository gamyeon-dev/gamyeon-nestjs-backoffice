# 관리자 수퍼계정
ADMIN_EMAIL=admin@gamyeon.com

# 평문 비밀번호 (ADMIN_PASSWORD_HASH가 없을 때 fallback으로 사용 — 개발 전용)
ADMIN_PASSWORD=your-dev-password

# bcrypt 해시 비밀번호 (프로덕션 권장)
# 생성: node -e "const b=require('bcrypt'); b.hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=

# JWT 설정
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gamyeon_backoffice
DB_SYNCHRONIZE=true
DB_LOGGING=false

# 서버 포트
PORT=3000

# 프론트엔드 URL (CORS origin)
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=gamyeon_backoffice
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_MIGRATIONS_RUN=false

# S3/스토리지 설정 (이미지 업로드)
S3_REGION=ap-northeast-2
S3_BUCKET=gamyeon-backoffice-dev
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# S3 호환 스토리지(MinIO 등) 사용 시 지정
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# 파일 공개 URL base (CDN/커스텀 도메인)
S3_PUBLIC_BASE_URL=
